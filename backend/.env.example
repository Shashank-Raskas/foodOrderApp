# ═══════════════════════════════════════════════════
# Payment Gateway API Keys
# Copy this file as .env.development or .env.production
# and fill in your credentials from each provider's dashboard.
# ═══════════════════════════════════════════════════

# ── Razorpay ──
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── PhonePe ──
# Dashboard: https://developer.phonepe.com/
PHONEPE_MERCHANT_ID=MERCHANTUAT
PHONEPE_SALT_KEY=099eb0cd-02cf-4e2a-8aca-3e6c6aff0399
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT

# ── Cashfree ──
# Dashboard: https://merchant.cashfree.com/
CASHFREE_APP_ID=TEST_APP_ID
CASHFREE_SECRET_KEY=TEST_SECRET_KEY
CASHFREE_ENV=sandbox

# ── App ──
FRONTEND_URL=http://localhost:5173
